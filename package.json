{
  "name": "@kitz/workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "author": {
    "name": "Jason Kuhrt",
    "url": "https://kuhrt.me"
  },
  "packageManager": "bun@1.3.6",
  "engines": {
    "bun": ">=1.3.6"
  },
  "scripts": {
    "install:ci": "bun install --frozen-lockfile",
    "build:packages": "bun run --workspaces build",
    "format": "sh -lc 'bash tools/format-repo.sh'",
    "format:check": "sh -lc 'bash tools/format-repo.sh --check'",
    "check:lint": "oxlint --import-plugin packages",
    "check:lint:type-aware": "oxlint --type-aware --import-plugin packages",
    "check:lint:packages": "bun run --workspaces check:lint",
    "check:lint:packages:type-aware": "bun run --workspaces check:lint -- --type-aware",
    "check:lint:strict-custom-rules": "oxlint --config .oxlintrc.custom-strict.json --import-plugin packages",
    "check:lint:strict-custom-rules:type-aware": "oxlint --type-aware --config .oxlintrc.custom-strict.json --import-plugin packages",
    "check:types": "bun run --workspaces check:types",
    "check:types:packages": "bun run --workspaces check:types",
    "check:package:packages": "sh -lc 'bun run build:packages && bun run --workspaces check:package'",
    "test:packages": "sh -lc 'bun run build:packages && bun run --if-present --workspaces test'",
    "test:oxlint-custom-rules": "vitest run tools/oxlint-custom-rules/tests/custom-rules.test.ts",
    "check:api-model-style": "bun tools/check-api-model-style.mjs",
    "release:build": "bun run build:packages",
    "release:forecast:comment": "bun packages/release/build/cli/cli.js forecast --format comment",
    "release:plan:ephemeral": "bun packages/release/build/cli/cli.js plan --lifecycle ephemeral",
    "release:apply:ephemeral": "bun packages/release/build/cli/cli.js apply --yes --tag pr",
    "_:build": "tsgo -p tsconfig.build.json",
    "_:dev": "tsgo -p tsconfig.build.json --watch",
    "_:check:types": "bun run --workspaces check:types",
    "_:check:lint": "oxlint src/",
    "_:check:package": "publint && attw --pack --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error",
    "release": "bun packages/release/build/cli/cli.js"
  },
  "trustedDependencies": [
    "better-sqlite3",
    "esbuild",
    "oxfmt"
  ],
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@ark/attest": "^0.56.0",
    "@ark/attest-ts-default": "npm:typescript@^5.9.3",
    "@effect/vitest": "^0.27.0",
    "@tsconfig/node-lts": "^24.0.0",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.0.3",
    "@typescript/native-preview": "^7.0.0-dev",
    "effect": "^3.19.13",
    "fast-check": "^4.4.0",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.34.0",
    "oxlint-tsgolint": "^0.16.0",
    "publint": "^0.3.16",
    "vite-tsconfig-paths": "^6.0.3",
    "vitest": "^4.0.16"
  }
}
