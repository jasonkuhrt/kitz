{
  "name": "@kitz/workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "author": {
    "name": "Jason Kuhrt",
    "url": "https://kuhrt.me"
  },
  "packageManager": "bun@1.3.6",
  "engines": {
    "bun": ">=1.3.6"
  },
  "scripts": {
    "install:ci": "bun install --frozen-lockfile",
    "hooks:install": "bun tools/install-hooks.ts",
    "prepare": "bun run hooks:install",
    "build:packages": "bun run --workspaces build",
    "fix": "bun run fix:format && bun run fix:lint",
    "fix:format": "bun tools/run-format.ts",
    "fix:lint": "bun tools/run-lint.ts --import-plugin packages --fix-dangerously",
    "format": "bun run fix:format",
    "check:format": "bun tools/run-format.ts --check",
    "format:check": "bun run check:format",
    "check:lint": "bun tools/run-lint.ts --import-plugin packages",
    "check:lint:type-aware": "bun tools/run-lint.ts --type-aware --import-plugin packages",
    "check:lint:packages": "bun run --workspaces check:lint",
    "check:lint:packages:type-aware": "bun run --workspaces check:lint -- --type-aware",
    "check:lint:strict-custom-rules": "bun tools/run-lint.ts --config .oxlintrc.custom-strict.json --import-plugin packages",
    "check:lint:strict-custom-rules:type-aware": "bun tools/run-lint.ts --type-aware --config .oxlintrc.custom-strict.json --import-plugin packages",
    "check:types": "bun run --workspaces check:types",
    "check:types:packages": "bun run --workspaces check:types",
    "check:package:packages": "sh -lc 'bun run build:packages && bun run --workspaces check:package'",
    "test:packages": "bun run --if-present --workspaces test",
    "test:oxlint-rules": "bun run test:oxlint-custom-rules && bun run --cwd packages/oxlint-rules test",
    "test:oxlint-custom-rules": "vitest run tools/oxlint-custom-rules/tests/custom-rules.test.ts",
    "check:api-model-style": "oxlint --config .oxlintrc.api-model-style.json --import-plugin packages",
    "check:release": "bun run --cwd packages/release check:types && bun run --cwd packages/release check:lint",
    "check:platform": "bun run --cwd packages/platform check:types && bun run --cwd packages/platform check:lint && bun run --cwd packages/platform build && bun run --cwd packages/platform check:package",
    "release:build": "bun run build:packages",
    "release:test": "bun run --cwd packages/release test",
    "release:verify": "bun run check:release && bun run release:test",
    "platform:verify": "bun run check:platform",
    "pre-commit": "bun tools/pre-commit.ts",
    "release:plan:ephemeral": "bun run release plan --lifecycle ephemeral",
    "release:apply:ephemeral": "bun run release apply --yes --tag pr",
    "_:build": "tsgo -p tsconfig.build.json",
    "_:dev": "tsgo -p tsconfig.build.json --watch",
    "_:check:types": "bun run --workspaces check:types",
    "_:check:lint": "oxlint src/",
    "_:check:package": "publint && attw --pack --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error",
    "release": "bun packages/release/src/cli/cli.ts"
  },
  "trustedDependencies": [
    "better-sqlite3",
    "esbuild",
    "oxfmt"
  ],
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@ark/attest": "^0.56.0",
    "@ark/attest-ts-default": "npm:typescript@^5.9.3",
    "@effect/vitest": "4.0.0-beta.31",
    "@tsconfig/node-lts": "^24.0.0",
    "@tsconfig/strictest": "^2.0.8",
    "@types/node": "^25.0.3",
    "@typescript/native-preview": "^7.0.0-dev",
    "effect": "4.0.0-beta.31",
    "fast-check": "^4.4.0",
    "oxfmt": "^0.36.0",
    "@oxlint/plugins": "^1.55.0",
    "oxlint": "1.34.0",
    "oxlint-tsgolint": "^0.16.0",
    "publint": "^0.3.16",
    "vite-tsconfig-paths": "^6.0.3",
    "vitest": "^4.0.16"
  }
}
