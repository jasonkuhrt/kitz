{
  "name": "@kitz/workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "catalog": {
    "effect": "4.0.0-beta.76",
    "@effect/platform-bun": "4.0.0-beta.76",
    "@effect/platform-node": "4.0.0-beta.76",
    "@effect/sql-sqlite-bun": "4.0.0-beta.76",
    "@effect/sql-sqlite-node": "4.0.0-beta.76",
    "type-fest": "^5.7.0",
    "ansis": "^4.3.1",
    "fast-check": "^4.8.0",
    "object-inspect": "^1.13.4",
    "@types/object-inspect": "^1.13.0"
  },
  "author": {
    "name": "Jason Kuhrt",
    "url": "https://kuhrt.me"
  },
  "packageManager": "bun@1.3.6",
  "engines": {
    "bun": ">=1.3.6"
  },
  "scripts": {
    "install:ci": "bun install --frozen-lockfile",
    "prepare": "git config core.hooksPath hooks",
    "build:packages": "bun run --workspaces build",
    "fix": "bun run fix:format && bun run fix:lint",
    "fix:format": "bun tools/run-format.ts",
    "fix:lint": "bun tools/run-lint.ts --fix-dangerously",
    "format": "bun run fix:format",
    "check:format": "bun tools/run-format.ts --check",
    "format:check": "bun run check:format",
    "check:lint": "bun tools/run-lint.ts",
    "check:lint:type-aware": "bun tools/run-lint.ts --type-aware",
    "check:lint:packages": "bun run --workspaces check:lint",
    "check:lint:packages:type-aware": "bun run --workspaces check:lint -- --type-aware",
    "check:types": "bun run --workspaces check:types",
    "check:types:packages": "bun run --workspaces check:types",
    "check:package:packages": "sh -lc 'bun run build:packages && bun run --workspaces check:package'",
    "test:packages": "bun tools/run-package-tests.ts test --if-present",
    "check:cov:packages": "./tools/run-workspace-coverage.mjs",
    "check:ci": "actionlint",
    "check:platform": "bun run --cwd packages/platform check:types && bun run --cwd packages/platform check:lint && bun run --cwd packages/platform build && bun run --cwd packages/platform check:package",
    "platform:verify": "bun run check:platform",
    "pre-commit": "bun tools/pre-commit.ts",
    "_:build": "tsgo -p tsconfig.build.json",
    "_:dev": "tsgo -p tsconfig.build.json --watch",
    "_:check:types": "bun run --workspaces check:types",
    "_:check:lint": "oxlint src/",
    "_:check:package": "publint && attw --pack --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error"
  },
  "trustedDependencies": [
    "better-sqlite3",
    "esbuild",
    "oxfmt"
  ],
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@oxlint/plugins": "^1.68.0",
    "@tsconfig/node-lts": "^24.0.0",
    "@tsconfig/strictest": "^2.0.8",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "^7.0.0-dev.20260603.1",
    "effect": "catalog:",
    "fast-check": "catalog:",
    "oxfmt": "^0.53.0",
    "oxlint": "1.68.0",
    "oxlint-tsgolint": "^0.23.0",
    "publint": "^0.3.21",
    "tinybench": "^6.0.2"
  }
}
