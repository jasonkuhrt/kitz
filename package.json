{
  "name": "@kitz/workspace",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "author": {
    "name": "Jason Kuhrt",
    "url": "https://kuhrt.me"
  },
  "packageManager": "pnpm@11.4.0",
  "engines": {
    "bun": ">=1.3.6",
    "pnpm": ">=11.4.0"
  },
  "scripts": {
    "fleet:scan": "bun tools/fleet.ts scan",
    "fleet:scan:json": "bun tools/fleet.ts scan --json",
    "fleet:link": "bun tools/fleet.ts link --no-save",
    "fleet:link:dry-run": "bun tools/fleet.ts link --dry-run --no-save",
    "fleet:link:save": "bun tools/fleet.ts link --save",
    "install:ci": "pnpm install --frozen-lockfile",
    "prepare": "git config core.hooksPath hooks",
    "build:packages": "pnpm -r --if-present run build",
    "fix": "pnpm run fix:format && pnpm run fix:lint",
    "fix:format": "bun tools/run-format.ts",
    "fix:lint": "bun tools/run-lint.ts --import-plugin packages --fix-dangerously",
    "format": "pnpm run fix:format",
    "check:format": "bun tools/run-format.ts --check",
    "format:check": "pnpm run check:format",
    "check:lint": "bun tools/run-lint.ts --import-plugin packages",
    "check:lint:type-aware": "bun tools/run-lint.ts --type-aware --import-plugin packages",
    "check:lint:packages": "pnpm -r --if-present run check:lint",
    "check:lint:packages:type-aware": "pnpm -r --if-present run check:lint -- --type-aware",
    "check:lint:strict-custom-rules": "bun tools/run-lint.ts --config .oxlintrc.custom-strict.json --import-plugin packages",
    "check:lint:strict-custom-rules:type-aware": "bun tools/run-lint.ts --type-aware --config .oxlintrc.custom-strict.json --import-plugin packages",
    "check:types": "pnpm -r --if-present run check:types",
    "check:types:packages": "pnpm -r --if-present run check:types",
    "check:package:packages": "pnpm run build:packages && pnpm -r --if-present run check:package",
    "test:packages": "bun tools/run-package-tests.ts test --if-present",
    "check:cov:packages": "./tools/run-workspace-coverage.mjs",
    "check:ci": "actionlint",
    "test:oxlint-rules": "pnpm run test:oxlint-custom-rules && pnpm --dir packages/oxlint-rules run test",
    "test:fleet": "bun test tools/fleet-lib.test.ts",
    "test:oxlint-custom-rules": "bun test tools/oxlint-custom-rules/tests/custom-rules.test.ts",
    "check:api-model-style": "bun tools/run-lint.ts --config .oxlintrc.api-model-style.json --import-plugin packages",
    "check:release": "pnpm --dir packages/release run check:types && pnpm --dir packages/release run check:lint",
    "check:platform": "pnpm --dir packages/platform run check:types && pnpm --dir packages/platform run check:lint && pnpm --dir packages/platform run build && pnpm --dir packages/platform run check:package",
    "release:build": "pnpm run build:packages",
    "release:test": "pnpm --dir packages/release run test",
    "release:verify": "pnpm run check:release && pnpm run release:test",
    "platform:verify": "pnpm run check:platform",
    "pre-commit": "bun tools/pre-commit.ts",
    "release:plan:ephemeral": "pnpm run release plan --lifecycle ephemeral",
    "release:apply:ephemeral": "pnpm run release apply --yes --tag pr",
    "_:build": "tsgo -p tsconfig.build.json",
    "_:dev": "tsgo -p tsconfig.build.json --watch",
    "_:check:types": "pnpm -r --if-present run check:types",
    "_:check:lint": "oxlint src/",
    "_:check:package": "publint && attw --pack --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error",
    "release": "bun packages/release/src/cli/cli.ts"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@oxlint/plugins": "^1.67.0",
    "@tsconfig/node-lts": "^24.0.0",
    "@tsconfig/strictest": "^2.0.8",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "@typescript/native-preview": "^7.0.0-dev.20260526.1",
    "effect": "4.0.0-beta.70",
    "fast-check": "^4.8.0",
    "oxfmt": "^0.52.0",
    "oxlint": "1.67.0",
    "oxlint-tsgolint": "^0.23.0",
    "publint": "^0.3.21",
    "tinybench": "^6.0.2"
  }
}
