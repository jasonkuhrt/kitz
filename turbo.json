{
  "$schema": "https://turbo.build/schema.json",
  "globalEnv": ["OXLINT_TSGOLINT_PATH"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["build/**"],
      "inputs": ["src/**", "tsconfig.json", "tsconfig.build.json", "package.json"]
    },
    "check:types": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "check:lint": {
      "outputs": []
    },
    "check:package": {
      "dependsOn": ["build"],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
