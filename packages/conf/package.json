{
  "name": "@kitz/conf",
  "version": "0.0.0-kitz-release",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonkuhrt/kitz.git"
  },
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#conf": {
      "types": "./build/_.js",
      "default": "./src/_.ts"
    },
    "#conf/*": {
      "types": "./build/*.js",
      "default": "./src/*.ts"
    },
    "#configurator": {
      "types": "./build/configurator.js",
      "default": "./src/configurator.ts"
    },
    "#file": {
      "types": "./build/file/__.js",
      "default": "./src/file/__.ts"
    },
    "#file/*": {
      "types": "./build/file/*.js",
      "default": "./src/file/*.ts"
    }
  },
  "types": "./src/_.ts",
  "exports": {
    ".": {
      "types": "./build/_.js",
      "default": "./src/_.ts"
    },
    "./__": {
      "types": "./build/__.js",
      "default": "./src/__.ts"
    }
  },
  "files": [
    "build",
    "src"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "dev": "tsgo -p tsconfig.build.json --watch",
    "check:types": "tsgo --noEmit",
    "check:lint": "oxlint src/",
    "check:package": "publint && attw --pack --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error"
  },
  "dependencies": {
    "@effect/platform": "*",
    "@kitz/core": "workspace:*",
    "@kitz/env": "workspace:*",
    "@kitz/fs": "workspace:*",
    "@kitz/mod": "workspace:*",
    "@kitz/sch": "workspace:*",
    "effect": "*",
    "type-fest": "*"
  }
}
