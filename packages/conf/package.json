{
  "name": "@kitz/conf",
  "version": "0.0.0-kitz-release",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonkuhrt/kitz.git"
  },
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#conf": "./src/_.ts",
    "#conf/*": "./src/*.ts",
    "#configurator": "./src/configurator.ts",
    "#file": "./src/file/__.ts",
    "#file/*": "./src/file/*.ts"
  },
  "exports": {
    ".": "./src/_.ts",
    "./__": "./src/__.ts"
  },
  "files": [
    "build",
    "src"
  ],
  "scripts": {
    "build": "tsgo -b tsconfig.build.json --clean && tsgo -b tsconfig.build.json",
    "dev": "tsgo -p tsconfig.build.json --watch",
    "check:types": "tsgo --noEmit",
    "check:lint": "oxlint src/",
    "check:package": "publint && attw --pack --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error"
  },
  "dependencies": {
    "@kitz/core": "workspace:*",
    "@kitz/env": "workspace:*",
    "@kitz/fs": "workspace:*",
    "@kitz/mod": "workspace:*",
    "@kitz/sch": "workspace:*",
    "effect": "4.0.0-beta.31",
    "type-fest": "*"
  }
}
