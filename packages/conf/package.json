{
  "name": "@kitz/conf",
  "version": "0.0.0-kitz-release",
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#conf": {
      "types": "./src/_.ts",
      "default": "./build/_.js"
    },
    "#conf/*": {
      "types": "./src/*.ts",
      "default": "./build/*.js"
    },
    "#configurator": {
      "types": "./src/configurator.ts",
      "default": "./build/configurator.js"
    },
    "#file": {
      "types": "./src/file/__.ts",
      "default": "./build/file/__.js"
    },
    "#file/*": {
      "types": "./src/file/*.ts",
      "default": "./build/file/*.js"
    }
  },
  "types": "./src/_.ts",
  "exports": {
    ".": {
      "types": "./src/_.ts",
      "default": "./build/_.js"
    },
    "./__": {
      "types": "./src/__.ts",
      "default": "./build/__.js"
    }
  },
  "files": [
    "build",
    "src"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "dev": "tsgo -p tsconfig.build.json --watch",
    "check:types": "tsgo --noEmit",
    "check:lint": "oxlint src/",
    "check:package": "publint && attw --pack --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error"
  },
  "dependencies": {
    "@effect/platform": "*",
    "@kitz/core": "workspace:*",
    "@kitz/env": "workspace:*",
    "@kitz/fs": "workspace:*",
    "@kitz/mod": "workspace:*",
    "@kitz/sch": "workspace:*",
    "effect": "*",
    "type-fest": "*"
  }
}
