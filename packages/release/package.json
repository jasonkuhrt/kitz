{
  "name": "@kitz/release",
  "version": "0.0.0-kitz-release",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonkuhrt/kitz.git"
  },
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#release": "./src/_.ts",
    "#release/*": "./src/*.ts",
    "#platform:executor/sqlite-client": {
      "bun": "./src/api/executor/sqlite-client.bun.ts",
      "default": "./src/api/executor/sqlite-client.node.ts"
    }
  },
  "exports": {
    ".": "./src/_.ts",
    "./__": "./src/__.ts"
  },
  "files": [
    "build",
    "src"
  ],
  "scripts": {
    "build": "tsgo -b tsconfig.build.json --clean && tsgo -b tsconfig.build.json",
    "dev": "tsgo -p tsconfig.build.json --watch",
    "check:types": "tsgo --noEmit",
    "check:lint": "oxlint src/",
    "check:package": "publint && attw --pack --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error",
    "test": "vitest run --root ../.. packages/release/src"
  },
  "bin": {
    "release": "./build/cli/cli.js"
  },
  "dependencies": {
    "@effect/sql-sqlite-bun": "4.0.0-beta.31",
    "@effect/sql-sqlite-node": "4.0.0-beta.31",
    "@kitz/cli": "workspace:*",
    "@kitz/conf": "workspace:*",
    "@kitz/conventional-commits": "workspace:*",
    "@kitz/core": "workspace:*",
    "@kitz/env": "workspace:*",
    "@kitz/flo": "workspace:*",
    "@kitz/fs": "workspace:*",
    "@kitz/git": "workspace:*",
    "@kitz/github": "workspace:*",
    "@kitz/mod": "workspace:*",
    "@kitz/monorepo": "workspace:*",
    "@kitz/npm-registry": "workspace:*",
    "@kitz/oak": "workspace:*",
    "@kitz/platform": "workspace:*",
    "@kitz/pkg": "workspace:*",
    "@kitz/resource": "workspace:*",
    "@kitz/semver": "workspace:*",
    "effect": "4.0.0-beta.31"
  },
  "devDependencies": {
    "@kitz/test": "workspace:*"
  }
}
