{
  "name": "@kitz/release",
  "version": "0.0.0-kitz-release",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonkuhrt/kitz.git"
  },
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#release": "./src/__.ts",
    "#release/*": "./src/*.ts",
    "#platform:executor/sqlite-client": {
      "bun": "./src/api/executor/sqlite-client.bun.ts",
      "default": "./src/api/executor/sqlite-client.node.ts"
    }
  },
  "exports": {
    ".": "./src/__.ts",
    "./__": "./src/__.ts",
    "./promise-api": "./src/promise-api.ts"
  },
  "files": [
    "build",
    "src"
  ],
  "scripts": {
    "build": "tsgo -b tsconfig.build.json --clean && tsgo -b tsconfig.build.json",
    "dev": "tsgo -p tsconfig.build.json --watch",
    "check:types": "tsgo --noEmit",
    "check:lint": "bun ../../tools/run-lint.ts src/",
    "check:package": "publint && attw --pack --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error",
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "check:cov": "bun run test:coverage"
  },
  "bin": {
    "release": "./build/cli/cli.js"
  },
  "dependencies": {
    "@effect/sql-sqlite-bun": "catalog:",
    "@effect/sql-sqlite-node": "catalog:",
    "@kitz/cli": "workspace:*",
    "@kitz/conf": "workspace:*",
    "@kitz/conventional-commits": "workspace:*",
    "@kitz/core": "workspace:*",
    "@kitz/env": "workspace:*",
    "@kitz/flo": "workspace:*",
    "@kitz/fs": "workspace:*",
    "@kitz/git": "workspace:*",
    "@kitz/github": "workspace:*",
    "@kitz/json": "workspace:*",
    "@kitz/mod": "workspace:*",
    "@kitz/monorepo": "workspace:*",
    "@kitz/npm-registry": "workspace:*",
    "@kitz/num": "workspace:*",
    "@kitz/pkg": "workspace:*",
    "@kitz/platform": "workspace:*",
    "@kitz/resource": "workspace:*",
    "@kitz/semver": "workspace:*",
    "@kitz/tui": "workspace:*",
    "@opentui/core": "0.3.1",
    "@opentui/react": "0.3.1",
    "effect": "catalog:",
    "react": "19.2.7"
  },
  "devDependencies": {
    "@kitz/otel": "workspace:*",
    "@kitz/test": "workspace:*",
    "@kitz/yaml": "workspace:*",
    "@types/react": "^19.2.16"
  }
}
