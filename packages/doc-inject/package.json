{
  "name": "@kitz/doc-inject",
  "version": "0.0.0-kitz-release",
  "type": "module",
  "sideEffects": false,
  "types": "./src/_.ts",
  "bin": {
    "doc-inject": "./build/cli.js"
  },
  "imports": {
    "#doc-inject": "./src/_.ts",
    "#doc-inject/*": "./src/*.ts"
  },
  "exports": {
    ".": {
      "types": "./src/_.ts",
      "default": "./build/_.js"
    },
    "./__": {
      "types": "./src/__.ts",
      "default": "./build/__.js"
    }
  },
  "files": [
    "build",
    "src"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "dev": "tsgo -p tsconfig.build.json --watch",
    "check:types": "tsgo --noEmit",
    "check:lint": "oxlint --config ../../.oxlintrc.json src/",
    "check:package": "publint && attw --pack --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error"
  },
  "dependencies": {
    "@effect/platform": "^0.94.0",
    "@effect/platform-node": "^0.104.0",
    "@kitz/core": "workspace:*",
    "effect": "^3.19.13"
  }
}
