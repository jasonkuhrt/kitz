    "#undefined": {
      "types": "./build/undefined/_.js",
      "default": "./src/undefined/_.ts"
    },
    "#undefined/*": {
      "types": "./build/undefined/*.js",
      "default": "./src/undefined/*.ts"
    },
    "#prom": {
      "types": "./build/prom/_.js",
      "default": "./src/prom/_.ts"
    },
    "#prom/*": {
      "types": "./build/prom/*.js",
      "default": "./src/prom/*.ts"
    },
    "#prox": {
      "types": "./build/prox/_.js",
      "default": "./src/prox/_.ts"
    },
    "#prox/*": {
      "types": "./build/prox/*.js",
      "default": "./src/prox/*.ts"
    },
    "#deps/*": {
      "types": "./build/deps/*.js",
      "default": "./src/deps/*.ts"
    },
    "#platform:lang/*": {
      "types": "./build/lang/*.node.js",
      "browser": "./src/lang/*.browser.ts",
      "default": "./src/lang/*.node.ts"
    }
  },
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./build/index.js",
      "default": "./src/index.ts"
    },
    "./_internal/optic-lenses/array": {
      "types": "./build/optic/lenses/array.js",
      "default": "./src/optic/lenses/array.ts"
    },
    "./_internal/optic-lenses/awaited": {
      "types": "./build/optic/lenses/awaited.js",
      "default": "./src/optic/lenses/awaited.ts"
