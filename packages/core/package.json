{
  "name": "@kitz/core",
  "version": "0.0.0-kitz-release",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonkuhrt/kitz.git"
  },
  "description": "Core data structures and utilities",
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#arr": {
      "types": "./build/arr/_.js",
      "default": "./src/arr/_.ts"
    },
    "#arr/*": {
      "types": "./build/arr/*.js",
      "default": "./src/arr/*.ts"
    },
    "#bool": {
      "types": "./build/bool/_.js",
      "default": "./src/bool/_.ts"
    },
    "#bool/*": {
      "types": "./build/bool/*.js",
      "default": "./src/bool/*.ts"
    },
    "#date": {
      "types": "./build/date/_.js",
      "default": "./src/date/_.ts"
    },
    "#date/*": {
      "types": "./build/date/*.js",
      "default": "./src/date/*.ts"
    },
    "#err": {
      "types": "./build/err/_.js",
      "default": "./src/err/_.ts"
    },
    "#err/err": {
      "types": "./build/err/__.js",
      "default": "./src/err/__.ts"
    },
    "#err/core": {
      "types": "./build/err/core/_.js",
      "default": "./src/err/core/_.ts"
    },
    "#fn": {
      "types": "./build/fn/_.js",
