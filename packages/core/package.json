      "types": "./build/ts/simplify.js",
      "default": "./src/ts/simplify.ts"
    },
    "./_internal/ts/simple-signature": {
      "types": "./build/ts/simple-signature.js",
      "default": "./src/ts/simple-signature.ts"
    },
    "./_internal/ts/inhabitance": {
      "types": "./build/ts/inhabitance.js",
