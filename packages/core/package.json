{
  "name": "@kitz/core",
  "version": "0.0.0-kitz-release",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonkuhrt/kitz.git"
  },
  "description": "Core data structures and utilities",
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#arr": "./src/arr/_.ts",
    "#arr/*": "./src/arr/*.ts",
    "#bool": "./src/bool/_.ts",
    "#bool/*": "./src/bool/*.ts",
    "#date": "./src/date/_.ts",
    "#date/*": "./src/date/*.ts",
    "#err": "./src/err/_.ts",
    "#err/err": "./src/err/__.ts",
    "#err/core": "./src/err/core/_.ts",
    "#fn": "./src/fn/_.ts",
    "#fn/fn": "./src/fn/__.ts",
    "#fn/core": "./src/fn/core/_.ts",
    "#mask": "./src/mask/_.ts",
    "#mask/mask": "./src/mask/__.ts",
    "#lang": "./src/lang/_.ts",
    "#lang/lang": "./src/lang/__.ts",
    "#lang/core": "./src/lang/core/_.ts",
    "#lang/core/lang": "./src/lang/core/lang.ts",
    "#null": "./src/null/_.ts",
    "#null/*": "./src/null/*.ts",
    "#num": "./src/num/_.ts",
    "#num/*": "./src/num/*.ts",
    "#obj": "./src/obj/_.ts",
    "#obj/*": "./src/obj/*.ts",
    "#optic": "./src/optic/_.ts",
    "#optic/*": "./src/optic/*.ts",
    "#ref": "./src/ref/_.ts",
    "#ref/ref": "./src/ref/__.ts",
    "#pat": "./src/pat/_.ts",
    "#pat/*": "./src/pat/*.ts",
    "#rec": "./src/rec/_.ts",
    "#rec/*": "./src/rec/*.ts",
    "#str": "./src/str/_.ts",
    "#str/*": "./src/str/*.ts",
    "#ts": "./src/ts/_.ts",
    "#ts/ts": "./src/ts/__.ts",
    "#value": "./src/value/_.ts",
    "#value/value": "./src/value/__.ts",
    "#tup": "./src/tup/_.ts",
    "#tup/*": "./src/tup/*.ts",
    "#undefined": "./src/undefined/_.ts",
    "#undefined/*": "./src/undefined/*.ts",
    "#prom": "./src/prom/_.ts",
    "#prom/*": "./src/prom/*.ts",
    "#prox": "./src/prox/_.ts",
    "#prox/*": "./src/prox/*.ts",
    "#deps/*": "./src/deps/*.ts",
    "#platform:lang/*": {
      "browser": "./src/lang/*.browser.ts",
      "default": "./src/lang/*.node.ts"
    }
  },
  "exports": {
    ".": "./src/index.ts",
    "./_internal/optic-lenses/array": "./src/optic/lenses/array.ts",
    "./_internal/optic-lenses/awaited": "./src/optic/lenses/awaited.ts",
    "./_internal/optic-lenses/parameter1": "./src/optic/lenses/parameter1.ts",
    "./_internal/optic-lenses/parameter2": "./src/optic/lenses/parameter2.ts",
    "./_internal/optic-lenses/parameter3": "./src/optic/lenses/parameter3.ts",
    "./_internal/optic-lenses/parameter4": "./src/optic/lenses/parameter4.ts",
    "./_internal/optic-lenses/parameter5": "./src/optic/lenses/parameter5.ts",
    "./_internal/optic-lenses/parameters": "./src/optic/lenses/parameters.ts",
    "./_internal/optic-lenses/returned": "./src/optic/lenses/returned.ts",
    "./_internal/ts/err": "./src/ts/err.ts",
    "./_internal/ts/simplify": "./src/ts/simplify.ts",
    "./_internal/ts/simple-signature": "./src/ts/simple-signature.ts",
    "./_internal/ts/inhabitance": "./src/ts/inhabitance.ts",
    "./_internal/ts/union": "./src/ts/union.ts",
    "./_internal/ts/variance-phantom": "./src/ts/variance-phantom.ts",
    "./_internal/fn/kind": "./src/fn/kind.ts",
    "./arr": "./src/arr/__.ts",
    "./bool": "./src/bool/__.ts",
    "./date": "./src/date/__.ts",
    "./err": "./src/err/__.ts",
    "./fn": "./src/fn/__.ts",
    "./lang": "./src/lang/__.ts",
    "./null": "./src/null/__.ts",
    "./num": "./src/num/__.ts",
    "./obj": "./src/obj/__.ts",
    "./optic": "./src/optic/__.ts",
    "./pat": "./src/pat/__.ts",
    "./prom": "./src/prom/__.ts",
    "./prox": "./src/prox/__.ts",
    "./rec": "./src/rec/__.ts",
    "./str": "./src/str/__.ts",
    "./ts": "./src/ts/__.ts",
    "./tup": "./src/tup/__.ts",
    "./undefined": "./src/undefined/__.ts"
  },
  "files": [
    "build",
    "src"
  ],
  "scripts": {
    "build": "tsgo -b tsconfig.build.json --clean && tsgo -b tsconfig.build.json",
    "dev": "tsgo -p tsconfig.build.json --watch",
    "check:types": "tsgo --noEmit",
    "check:lint": "bun ../../tools/run-lint.ts src/",
    "check:package": "publint && attw --pack --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error",
    "test": "ATTEST=true vitest run --config ../../vitest.config.ts --root .",
    "test:coverage": "ATTEST=true vitest run --config ../../vitest.config.ts --root . --coverage",
    "check:cov": "bun run test:coverage"
  },
  "dependencies": {
    "ansis": "^4.2.0",
    "arkregex": "^0.0.5",
    "consola": "^3.4.2",
    "es-toolkit": "^1.43.0",
    "object-inspect": "^1.13.4",
    "pluralize-esm": "^9.0.5",
    "ts-toolbelt": "^9.6.0",
    "type-fest": "^5.3.1",
    "zod": "^4.2.1"
  },
  "peerDependencies": {
    "effect": "4.0.0-beta.31"
  },
  "peerDependenciesMeta": {
    "effect": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/object-inspect": "^1.13.0"
  }
}
