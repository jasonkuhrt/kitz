      "types": "./build/mask/__.js",
      "default": "./src/mask/__.ts"
    },
    "#lang": {
      "types": "./build/lang/_.js",
      "default": "./src/lang/_.ts"
    },
    "#lang/lang": {
      "types": "./build/lang/__.js",
      "default": "./src/lang/__.ts"
    },
    "#lang/core": {
      "types": "./build/lang/core/_.js",
      "default": "./src/lang/core/_.ts"
    },
    "#lang/core/lang": {
      "types": "./build/lang/core/lang.js",
      "default": "./src/lang/core/lang.ts"
    },
