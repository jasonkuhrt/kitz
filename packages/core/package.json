      "types": "./build/arr/__.js",
      "default": "./src/arr/__.ts"
    },
    "./bool": {
      "types": "./build/bool/__.js",
      "default": "./src/bool/__.ts"
    },
    "./date": {
      "types": "./build/date/__.js",
      "default": "./src/date/__.ts"
