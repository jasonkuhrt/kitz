{
  "name": "@kitz/core",
  "version": "0.0.0-kitz-release",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonkuhrt/kitz.git"
  },
  "description": "Core data structures and utilities",
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#arr": {
      "types": "./src/arr/_.ts",
      "default": "./build/arr/_.js"
    },
    "#arr/*": {
      "types": "./src/arr/*.ts",
      "default": "./build/arr/*.js"
    },
    "#bool": {
      "types": "./src/bool/_.ts",
      "default": "./build/bool/_.js"
    },
    "#bool/*": {
      "types": "./src/bool/*.ts",
      "default": "./build/bool/*.js"
    },
    "#date": {
      "types": "./src/date/_.ts",
      "default": "./build/date/_.js"
    },
    "#date/*": {
      "types": "./src/date/*.ts",
      "default": "./build/date/*.js"
    },
    "#err": {
      "types": "./src/err/_.ts",
      "default": "./build/err/_.js"
    },
    "#err/err": {
      "types": "./src/err/__.ts",
      "default": "./build/err/__.js"
    },
    "#err/core": {
      "types": "./src/err/core/_.ts",
      "default": "./build/err/core/_.js"
    },
    "#fn": {
      "types": "./src/fn/_.ts",
      "default": "./build/fn/_.js"
    },
    "#fn/fn": {
      "types": "./src/fn/__.ts",
      "default": "./build/fn/__.js"
    },
    "#fn/core": {
      "types": "./src/fn/core/_.ts",
      "default": "./build/fn/core/_.js"
    },
    "#mask": {
      "types": "./src/mask/_.ts",
      "default": "./build/mask/_.js"
    },
    "#mask/mask": {
      "types": "./src/mask/__.ts",
      "default": "./build/mask/__.js"
    },
    "#lang": {
      "types": "./src/lang/_.ts",
      "default": "./build/lang/_.js"
    },
    "#lang/lang": {
      "types": "./src/lang/__.ts",
      "default": "./build/lang/__.js"
    },
    "#lang/core": {
      "types": "./src/lang/core/_.ts",
      "default": "./build/lang/core/_.js"
    },
    "#lang/core/lang": {
      "types": "./src/lang/core/lang.ts",
      "default": "./build/lang/core/lang.js"
    },
    "#null": {
      "types": "./src/null/_.ts",
      "default": "./build/null/_.js"
    },
    "#null/*": {
      "types": "./src/null/*.ts",
      "default": "./build/null/*.js"
    },
    "#num": {
      "types": "./src/num/_.ts",
      "default": "./build/num/_.js"
    },
    "#num/*": {
      "types": "./src/num/*.ts",
      "default": "./build/num/*.js"
    },
    "#obj": {
      "types": "./src/obj/_.ts",
      "default": "./build/obj/_.js"
    },
    "#obj/*": {
      "types": "./src/obj/*.ts",
      "default": "./build/obj/*.js"
    },
    "#optic": {
      "types": "./src/optic/_.ts",
      "default": "./build/optic/_.js"
    },
    "#optic/*": {
      "types": "./src/optic/*.ts",
      "default": "./build/optic/*.js"
    },
    "#ref": {
      "types": "./src/ref/_.ts",
      "default": "./build/ref/_.js"
    },
    "#ref/ref": {
      "types": "./src/ref/__.ts",
      "default": "./build/ref/__.js"
    },
    "#pat": {
      "types": "./src/pat/_.ts",
      "default": "./build/pat/_.js"
    },
    "#pat/*": {
      "types": "./src/pat/*.ts",
      "default": "./build/pat/*.js"
    },
    "#rec": {
      "types": "./src/rec/_.ts",
      "default": "./build/rec/_.js"
    },
    "#rec/*": {
      "types": "./src/rec/*.ts",
      "default": "./build/rec/*.js"
    },
    "#str": {
      "types": "./src/str/_.ts",
      "default": "./build/str/_.js"
    },
    "#str/*": {
      "types": "./src/str/*.ts",
      "default": "./build/str/*.js"
    },
    "#ts": {
      "types": "./src/ts/_.ts",
      "default": "./build/ts/_.js"
    },
    "#ts/ts": {
      "types": "./src/ts/__.ts",
      "default": "./build/ts/__.js"
    },
    "#value": {
      "types": "./src/value/_.ts",
      "default": "./build/value/_.js"
    },
    "#value/value": {
      "types": "./src/value/__.ts",
      "default": "./build/value/__.js"
    },
    "#tup": {
      "types": "./src/tup/_.ts",
      "default": "./build/tup/_.js"
    },
    "#tup/*": {
      "types": "./src/tup/*.ts",
      "default": "./build/tup/*.js"
    },
    "#undefined": {
      "types": "./src/undefined/_.ts",
      "default": "./build/undefined/_.js"
    },
    "#undefined/*": {
      "types": "./src/undefined/*.ts",
      "default": "./build/undefined/*.js"
    },
    "#prom": {
      "types": "./src/prom/_.ts",
      "default": "./build/prom/_.js"
    },
    "#prom/*": {
      "types": "./src/prom/*.ts",
      "default": "./build/prom/*.js"
    },
    "#prox": {
      "types": "./src/prox/_.ts",
      "default": "./build/prox/_.js"
    },
    "#prox/*": {
      "types": "./src/prox/*.ts",
      "default": "./build/prox/*.js"
    },
    "#deps/*": {
      "types": "./src/deps/*.ts",
      "default": "./build/deps/*.js"
    },
    "#platform:lang/*": {
      "types": "./src/lang/*.node.ts",
      "browser": "./build/lang/*.browser.js",
      "default": "./build/lang/*.node.js"
    }
  },
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./build/index.js"
    },
    "./_internal/optic-lenses/array": {
      "types": "./src/optic/lenses/array.ts",
      "default": "./build/optic/lenses/array.js"
    },
    "./_internal/optic-lenses/awaited": {
      "types": "./src/optic/lenses/awaited.ts",
      "default": "./build/optic/lenses/awaited.js"
    },
    "./_internal/optic-lenses/parameter1": {
      "types": "./src/optic/lenses/parameter1.ts",
      "default": "./build/optic/lenses/parameter1.js"
    },
    "./_internal/optic-lenses/parameter2": {
      "types": "./src/optic/lenses/parameter2.ts",
      "default": "./build/optic/lenses/parameter2.js"
    },
    "./_internal/optic-lenses/parameter3": {
      "types": "./src/optic/lenses/parameter3.ts",
      "default": "./build/optic/lenses/parameter3.js"
    },
    "./_internal/optic-lenses/parameter4": {
      "types": "./src/optic/lenses/parameter4.ts",
      "default": "./build/optic/lenses/parameter4.js"
    },
    "./_internal/optic-lenses/parameter5": {
