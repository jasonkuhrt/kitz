      "default": "./build/optic/lenses/parameter5.js"
    },
    "./_internal/optic-lenses/parameters": {
      "types": "./src/optic/lenses/parameters.ts",
      "default": "./build/optic/lenses/parameters.js"
    },
    "./_internal/optic-lenses/returned": {
      "types": "./src/optic/lenses/returned.ts",
      "default": "./build/optic/lenses/returned.js"
    },
    "./_internal/ts/err": {
      "types": "./src/ts/err.ts",
      "default": "./build/ts/err.js"
    },
    "./_internal/ts/simplify": {
      "types": "./src/ts/simplify.ts",
      "default": "./build/ts/simplify.js"
    },
    "./_internal/ts/simple-signature": {
      "types": "./src/ts/simple-signature.ts",
      "default": "./build/ts/simple-signature.js"
    },
    "./_internal/ts/inhabitance": {
      "types": "./src/ts/inhabitance.ts",
      "default": "./build/ts/inhabitance.js"
    },
    "./_internal/ts/union": {
      "types": "./src/ts/union.ts",
      "default": "./build/ts/union.js"
    },
    "./_internal/ts/variance-phantom": {
      "types": "./src/ts/variance-phantom.ts",
      "default": "./build/ts/variance-phantom.js"
    },
    "./_internal/fn/kind": {
      "types": "./src/fn/kind.ts",
      "default": "./build/fn/kind.js"
    },
    "./arr": {
      "types": "./src/arr/__.ts",
      "default": "./build/arr/__.js"
    },
    "./bool": {
      "types": "./src/bool/__.ts",
      "default": "./build/bool/__.js"
    },
    "./date": {
      "types": "./src/date/__.ts",
      "default": "./build/date/__.js"
    },
    "./err": {
      "types": "./src/err/__.ts",
      "default": "./build/err/__.js"
    },
    "./fn": {
      "types": "./src/fn/__.ts",
      "default": "./build/fn/__.js"
    },
    "./lang": {
      "types": "./src/lang/__.ts",
      "default": "./build/lang/__.js"
    },
    "./null": {
      "types": "./src/null/__.ts",
      "default": "./build/null/__.js"
    },
    "./num": {
      "types": "./src/num/__.ts",
      "default": "./build/num/__.js"
    },
    "./obj": {
      "types": "./src/obj/__.ts",
      "default": "./build/obj/__.js"
    },
    "./optic": {
      "types": "./src/optic/__.ts",
      "default": "./build/optic/__.js"
    },
    "./pat": {
      "types": "./src/pat/__.ts",
      "default": "./build/pat/__.js"
    },
    "./prom": {
      "types": "./src/prom/__.ts",
      "default": "./build/prom/__.js"
    },
    "./prox": {
      "types": "./src/prox/__.ts",
      "default": "./build/prox/__.js"
    },
    "./rec": {
      "types": "./src/rec/__.ts",
      "default": "./build/rec/__.js"
    },
    "./str": {
      "types": "./src/str/__.ts",
      "default": "./build/str/__.js"
    },
    "./ts": {
      "types": "./src/ts/__.ts",
      "default": "./build/ts/__.js"
    },
    "./tup": {
      "types": "./src/tup/__.ts",
      "default": "./build/tup/__.js"
    },
    "./undefined": {
      "types": "./src/undefined/__.ts",
      "default": "./build/undefined/__.js"
    }
  },
  "files": [
    "build",
    "src"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "dev": "tsgo -p tsconfig.build.json --watch",
    "check:types": "tsgo --noEmit",
    "check:lint": "oxlint src/",
    "check:package": "publint && attw --pack --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error"
  },
  "dependencies": {
    "ansis": "^4.2.0",
    "arkregex": "^0.0.5",
    "consola": "^3.4.2",
    "es-toolkit": "^1.43.0",
    "object-inspect": "^1.13.4",
    "pluralize-esm": "^9.0.5",
    "ts-toolbelt": "^9.6.0",
    "type-fest": "^5.3.1",
    "zod": "^4.2.1"
  },
  "peerDependencies": {
    "effect": "^3.17.0"
  },
  "peerDependenciesMeta": {
    "effect": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/object-inspect": "^1.13.0"
  }
}
