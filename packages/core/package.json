{
  "name": "@kitz/core",
  "version": "0.0.0-kitz-release",
  "description": "Core data structures and utilities",
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#arr": "./src/arr/_.ts",
    "#arr/*": "./src/arr/*.ts",
    "#bool": "./src/bool/_.ts",
    "#bool/*": "./src/bool/*.ts",
    "#date": "./src/date/_.ts",
    "#date/*": "./src/date/*.ts",
    "#err": "./src/err/_.ts",
    "#err/err": "./src/err/__.ts",
    "#err/core": "./src/err/core/_.ts",
    "#fn": "./src/fn/_.ts",
    "#fn/fn": "./src/fn/__.ts",
    "#fn/core": "./src/fn/core/_.ts",
    "#mask": "./src/mask/_.ts",
    "#mask/mask": "./src/mask/__.ts",
    "#lang": "./src/lang/_.ts",
    "#lang/lang": "./src/lang/__.ts",
    "#lang/core": "./src/lang/core/_.ts",
    "#lang/core/lang": "./src/lang/core/lang.ts",
    "#null": "./src/null/_.ts",
    "#null/*": "./src/null/*.ts",
    "#num": "./src/num/_.ts",
    "#num/*": "./src/num/*.ts",
    "#obj": "./src/obj/_.ts",
    "#obj/*": "./src/obj/*.ts",
    "#optic": "./src/optic/_.ts",
    "#optic/*": "./src/optic/*.ts",
    "#ref": "./src/ref/_.ts",
    "#ref/ref": "./src/ref/__.ts",
    "#pat": "./src/pat/_.ts",
    "#pat/*": "./src/pat/*.ts",
    "#rec": "./src/rec/_.ts",
    "#rec/*": "./src/rec/*.ts",
    "#str": "./src/str/_.ts",
    "#str/*": "./src/str/*.ts",
    "#ts": "./src/ts/_.ts",
    "#ts/ts": "./src/ts/__.ts",
    "#value": "./src/value/_.ts",
    "#value/value": "./src/value/__.ts",
    "#tup": "./src/tup/_.ts",
    "#tup/*": "./src/tup/*.ts",
    "#undefined": "./src/undefined/_.ts",
    "#undefined/*": "./src/undefined/*.ts",
    "#prom": "./src/prom/_.ts",
    "#prom/*": "./src/prom/*.ts",
    "#prox": "./src/prox/_.ts",
    "#prox/*": "./src/prox/*.ts",
    "#deps/*": "./src/deps/*.ts",
    "#platform:lang/*": {
      "browser": "./build/lang/*.browser.js",
      "default": "./build/lang/*.node.js"
    }
  },
  "exports": {
    ".": "./build/index.js",
    "./_internal/optic-lenses/array": "./build/optic/lenses/array.js",
    "./_internal/optic-lenses/awaited": "./build/optic/lenses/awaited.js",
    "./_internal/optic-lenses/parameter1": "./build/optic/lenses/parameter1.js",
    "./_internal/optic-lenses/parameter2": "./build/optic/lenses/parameter2.js",
    "./_internal/optic-lenses/parameter3": "./build/optic/lenses/parameter3.js",
    "./_internal/optic-lenses/parameter4": "./build/optic/lenses/parameter4.js",
    "./_internal/optic-lenses/parameter5": "./build/optic/lenses/parameter5.js",
    "./_internal/optic-lenses/parameters": "./build/optic/lenses/parameters.js",
    "./_internal/optic-lenses/returned": "./build/optic/lenses/returned.js",
    "./_internal/ts/err": "./build/ts/err.js",
    "./_internal/ts/simplify": "./build/ts/simplify.js",
    "./_internal/ts/simple-signature": "./build/ts/simple-signature.js",
    "./_internal/ts/inhabitance": "./build/ts/inhabitance.js",
    "./_internal/ts/union": "./build/ts/union.js",
    "./_internal/ts/variance-phantom": "./build/ts/variance-phantom.js",
    "./_internal/fn/kind": "./build/fn/kind.js",
    "./arr": "./build/arr/__.js",
    "./bool": "./build/bool/__.js",
    "./date": "./build/date/__.js",
    "./err": "./build/err/__.js",
    "./fn": "./build/fn/__.js",
    "./lang": "./build/lang/__.js",
    "./null": "./build/null/__.js",
    "./num": "./build/num/__.js",
    "./obj": "./build/obj/__.js",
    "./optic": "./build/optic/__.js",
    "./pat": "./build/pat/__.js",
    "./prom": "./build/prom/__.js",
    "./prox": "./build/prox/__.js",
    "./rec": "./build/rec/__.js",
    "./str": "./build/str/__.js",
    "./ts": "./build/ts/__.js",
    "./tup": "./build/tup/__.js",
    "./undefined": "./build/undefined/__.js"
  },
  "files": [
    "build",
    "src"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "dev": "tsgo -p tsconfig.build.json --watch",
    "check:types": "tsgo --noEmit",
    "check:lint": "oxlint src/",
    "check:package": "publint && attw --pack --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error"
  },
  "dependencies": {
    "ansis": "^4.2.0",
    "arkregex": "^0.0.5",
    "consola": "^3.4.2",
    "es-toolkit": "^1.43.0",
    "object-inspect": "^1.13.4",
    "pluralize-esm": "^9.0.5",
    "ts-toolbelt": "^9.6.0",
    "type-fest": "^5.3.1",
    "zod": "^4.2.1"
  },
  "peerDependencies": {
    "effect": "^3.17.0"
  },
  "peerDependenciesMeta": {
    "effect": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/object-inspect": "^1.13.0"
  }
}
