      "default": "./src/rec/_.ts"
    },
    "#rec/*": {
      "types": "./build/rec/*.js",
      "default": "./src/rec/*.ts"
    },
    "#str": {
      "types": "./build/str/_.js",
      "default": "./src/str/_.ts"
    },
    "#str/*": {
      "types": "./build/str/*.js",
      "default": "./src/str/*.ts"
    },
    "#ts": {
      "types": "./build/ts/_.js",
      "default": "./src/ts/_.ts"
    },
    "#ts/ts": {
      "types": "./build/ts/__.js",
      "default": "./src/ts/__.ts"
