{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "noEmit": false,
    "declaration": true,
    "declarationMap": true,
    "paths": {
      "#sch": ["./src/_.js"],
      "#sch/*": ["./src/*.js"]
    }
  },
  "exclude": ["build", "node_modules", "**/*.test.ts", "**/*.test-d.ts", "**/*.bench-d.ts"]
}
