{
  "name": "@kitz/oak",
  "version": "0.0.0-kitz-release",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonkuhrt/kitz.git"
  },
  "description": "CLI argument parsing",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./build/_.js",
      "default": "./src/_.ts"
    },
    "./__": {
      "types": "./build/__.js",
      "default": "./src/__.ts"
    }
  },
  "dependencies": {
    "@kitz/assert": "workspace:*",
    "@kitz/cli": "workspace:*",
    "@kitz/core": "workspace:*",
    "@kitz/group": "workspace:*",
    "@kitz/tex": "workspace:*",
    "@standard-schema/spec": "*",
    "alge": "^0.8.1",
    "ansis": "*",
    "effect": "^3.0.0",
    "zod": "^4.2.1"
  },
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "dev": "tsgo -p tsconfig.build.json --watch",
    "check:types": "tsgo --noEmit",
    "check:lint": "oxlint src/",
    "check:package": "publint && attw --pack --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error"
  },
  "types": "./src/_.ts",
  "files": [
    "build",
    "src"
  ]
}
