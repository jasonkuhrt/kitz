{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./build",
    "tsBuildInfoFile": "./node_modules/.cache/.tsbuildinfo",
    "allowImportingTsExtensions": true,
    "types": ["node", "bun"],
    "noEmit": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["build", "node_modules"]
}
