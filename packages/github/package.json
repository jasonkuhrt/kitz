{
  "name": "@kitz/github",
  "version": "0.0.0-kitz-release",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonkuhrt/kitz.git"
  },
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#github": {
      "types": "./src/_.ts",
      "default": "./build/_.js"
    },
    "#github/*": {
      "types": "./src/*.ts",
      "default": "./build/*.js"
    }
  },
  "types": "./src/_.ts",
  "exports": {
    ".": {
      "types": "./src/_.ts",
      "default": "./build/_.js"
    },
    "./__": {
      "types": "./src/__.ts",
      "default": "./build/__.js"
    }
  },
  "files": [
    "build",
    "src"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "dev": "tsgo -p tsconfig.build.json --watch",
    "check:types": "tsgo --noEmit",
    "check:lint": "oxlint src/",
    "check:package": "publint && attw --pack --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error"
  },
  "dependencies": {
    "@kitz/core": "workspace:*",
    "@effect/platform": "^0.81.0",
    "@octokit/types": "^13.10.0",
    "effect": "^3.19.13"
  },
  "devDependencies": {
    "@effect/vitest": "^0.27.0",
    "@kitz/test": "workspace:*"
  }
}
