{
  "name": "@kitz/effect",
  "version": "0.1.0",
  "description": "Filesystem operations and a typed path ADT for the Effect ecosystem",
  "keywords": [
    "effect",
    "effect-ts",
    "filesystem",
    "fs",
    "path",
    "typescript",
    "schema"
  ],
  "license": "MIT",
  "author": {
    "name": "Jason Kuhrt",
    "url": "https://kuhrt.me"
  },
  "homepage": "https://github.com/jasonkuhrt/kitz/tree/main/packages/effect#readme",
  "bugs": {
    "url": "https://github.com/jasonkuhrt/kitz/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonkuhrt/kitz.git",
    "directory": "packages/effect"
  },
  "type": "module",
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "build"
  ],
  "exports": {
    ".": {
      "types": "./build/_.d.ts",
      "default": "./build/_.js"
    },
    "./FileSystem": {
      "types": "./build/__.d.ts",
      "default": "./build/__.js"
    },
    "./Path": {
      "types": "./build/path/_.d.ts",
      "default": "./build/path/_.js"
    },
    "./path/types/fileName": {
      "types": "./build/path/types/fileName.d.ts",
      "default": "./build/path/types/fileName.js"
    }
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json --clean && tsc -b tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "check:types": "tsc --noEmit",
    "check:lint": "vp lint src/",
    "check:package": "publint && attw --pack --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error",
    "test": "vp test run",
    "test:coverage": "vp test run --coverage",
    "check:cov": "vp test run --coverage"
  },
  "dependencies": {
    "tinyglobby": "^0.2.16"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "effect": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "effect": "^4.0.0-beta.85"
  }
}
