{
  "name": "@kitz/effect",
  "version": "0.1.0",
  "description": "Filesystem operations and a typed path ADT for the Effect ecosystem",
  "keywords": [
    "effect",
    "effect-ts",
    "filesystem",
    "fs",
    "path",
    "schema",
    "typescript"
  ],
  "homepage": "https://github.com/jasonkuhrt/kitz/tree/main/packages/effect#readme",
  "bugs": {
    "url": "https://github.com/jasonkuhrt/kitz/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Jason Kuhrt",
    "url": "https://kuhrt.me"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonkuhrt/kitz.git",
    "directory": "packages/effect"
  },
  "files": [
    "build"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./build/_.d.ts",
      "default": "./build/_.js"
    },
    "./FileSystem": {
      "types": "./build/__.d.ts",
      "default": "./build/__.js"
    },
    "./Path": {
      "types": "./build/path/_.d.ts",
      "default": "./build/path/_.js"
    },
    "./path/types/fileName": {
      "types": "./build/path/types/fileName.d.ts",
      "default": "./build/path/types/fileName.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "picomatch": "4.0.4"
  },
  "devDependencies": {
    "@kitz/vitest": "workspace:*",
    "@types/picomatch": "4.0.3",
    "@vitest/coverage-v8": "4.1.9",
    "effect": "catalog:"
  },
  "peerDependencies": {
    "effect": "^4.0.0-beta.85"
  }
}
