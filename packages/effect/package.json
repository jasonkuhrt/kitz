{
  "name": "@kitz/effect",
  "version": "0.0.0-kitz-release",
  "description": "Filesystem operations and a typed path ADT for the Effect ecosystem",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonkuhrt/kitz.git"
  },
  "files": [
    "build",
    "src"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/_.ts",
    "./FileSystem": "./src/__.ts",
    "./Path": "./src/path/_.ts",
    "./path/types/fileName": "./src/path/types/fileName.ts"
  },
  "scripts": {
    "build": "tsc -b tsconfig.build.json --clean && tsc -b tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "check:types": "tsc --noEmit",
    "check:lint": "vp lint src/",
    "check:package": "publint && attw --pack --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error",
    "test": "vp test run",
    "test:coverage": "vp test run --coverage",
    "check:cov": "vp test run --coverage"
  },
  "dependencies": {
    "tinyglobby": "^0.2.16"
  },
  "devDependencies": {
    "@effect/vitest": "catalog:",
    "effect": "catalog:",
    "vitest": "catalog:"
  },
  "peerDependencies": {
    "effect": "^4.0.0-beta.85"
  }
}
