{
  "name": "@kitz/cmx",
  "version": "0.0.0-kitz-release",
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#cmx": "./src/_.ts",
    "#cmx/*": "./src/*.ts"
  },
  "exports": {
    ".": "./src/_.ts",
    "./__": "./src/__.ts"
  },
  "files": [
    "build",
    "src"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "dev": "tsgo -p tsconfig.build.json --watch",
    "check:types": "tsgo --noEmit",
    "check:lint": "oxlint --config ../../oxlint.json src/",
    "check:package": "publint && attw --pack"
  },
  "dependencies": {
    "@kitz/core": "workspace:*"
  }
}
