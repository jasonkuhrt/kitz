{
  "name": "@kitz/cmx",
  "version": "0.0.0-kitz-release",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonkuhrt/kitz.git"
  },
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#cmx": "./src/_.ts",
    "#cmx/*": "./src/*.ts"
  },
  "exports": {
    ".": "./src/_.ts",
    "./__": "./src/__.ts"
  },
  "files": [
    "build",
    "src"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "dev": "tsgo -p tsconfig.build.json --watch",
    "check:types": "tsgo --noEmit",
    "check:lint": "oxlint --config ../../.oxlintrc.json src/",
    "check:package": "publint && attw --pack --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error",
    "test": "vitest run --config ../../vitest.config.ts --root .",
    "bench": "vitest bench --config ../../vitest.config.ts --root ."
  },
  "dependencies": {
    "@kitz/core": "workspace:*",
    "@kitz/fuzzy": "workspace:*",
    "@kitz/sch": "workspace:*"
  }
}
