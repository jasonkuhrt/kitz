{
  "name": "kitz",
  "version": "0.0.0-kitz-release",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonkuhrt/kitz.git"
  },
  "description": "A TypeScript standard library",
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts",
    "./arr": "./src/arr.ts",
    "./bool": "./src/bool.ts",
    "./date": "./src/date.ts",
    "./err": "./src/err.ts",
    "./fn": "./src/fn.ts",
    "./lang": "./src/lang.ts",
    "./null": "./src/null.ts",
    "./num": "./src/num.ts",
    "./obj": "./src/obj.ts",
    "./optic": "./src/optic.ts",
    "./pat": "./src/pat.ts",
    "./prom": "./src/prom.ts",
    "./prox": "./src/prox.ts",
    "./rec": "./src/rec.ts",
    "./str": "./src/str.ts",
    "./ts": "./src/ts.ts",
    "./tup": "./src/tup.ts",
    "./undefined": "./src/undefined.ts",
    "./assert": "./src/assert.ts",
    "./bldr": "./src/bldr.ts",
    "./cli": "./src/cli.ts",
    "./color": "./src/color.ts",
    "./conf": "./src/conf.ts",
    "./env": "./src/env.ts",
    "./fs": "./src/fs.ts",
    "./group": "./src/group.ts",
    "./html": "./src/html.ts",
    "./http": "./src/http.ts",
    "./idx": "./src/idx.ts",
    "./json": "./src/json.ts",
    "./jsonc": "./src/jsonc.ts",
    "./log": "./src/log.ts",
    "./mod": "./src/mod.ts",
    "./name": "./src/name.ts",
    "./oak": "./src/oak.ts",
    "./pkg": "./src/pkg.ts",
    "./paka": "./src/paka.ts",
    "./platform": "./src/platform.ts",
    "./resource": "./src/resource.ts",
    "./sch": "./src/sch.ts",
    "./semver": "./src/semver.ts",
    "./syn": "./src/syn.ts",
    "./test": "./src/test.ts",
    "./tex": "./src/tex.ts",
    "./tree": "./src/tree.ts",
    "./url": "./src/url.ts",
    "./ware": "./src/ware.ts",
    "./yaml": "./src/yaml.ts",
    "./monorepo": "./src/monorepo.ts"
  },
  "files": [
    "build",
    "src"
  ],
  "scripts": {
    "build": "tsgo -b tsconfig.build.json --clean && tsgo -b tsconfig.build.json",
    "dev": "tsgo -p tsconfig.build.json --watch",
    "check:types": "tsgo --noEmit",
    "check:lint": "bun ../../tools/run-lint.ts src/",
    "check:package": "publint && attw --pack --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error"
  },
  "dependencies": {
    "@kitz/assert": "workspace:*",
    "@kitz/bldr": "workspace:*",
    "@kitz/cli": "workspace:*",
    "@kitz/color": "workspace:*",
    "@kitz/conf": "workspace:*",
    "@kitz/core": "workspace:*",
    "@kitz/env": "workspace:*",
    "@kitz/fs": "workspace:*",
    "@kitz/group": "workspace:*",
    "@kitz/html": "workspace:*",
    "@kitz/http": "workspace:*",
    "@kitz/idx": "workspace:*",
    "@kitz/json": "workspace:*",
    "@kitz/jsonc": "workspace:*",
    "@kitz/log": "workspace:*",
    "@kitz/mod": "workspace:*",
    "@kitz/monorepo": "workspace:*",
    "@kitz/name": "workspace:*",
    "@kitz/num": "workspace:*",
    "@kitz/oak": "workspace:*",
    "@kitz/platform": "workspace:*",
    "@kitz/pkg": "workspace:*",
    "@kitz/paka": "workspace:*",
    "@kitz/resource": "workspace:*",
    "@kitz/sch": "workspace:*",
    "@kitz/semver": "workspace:*",
    "@kitz/syn": "workspace:*",
    "@kitz/test": "workspace:*",
    "@kitz/tex": "workspace:*",
    "@kitz/tree": "workspace:*",
    "@kitz/url": "workspace:*",
    "@kitz/ware": "workspace:*",
    "@kitz/yaml": "workspace:*"
  }
}
