{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./build",
    "tsBuildInfoFile": "./node_modules/.cache/.tsbuildinfo",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "paths": {
      "#monorepo": ["./src/_.js"],
      "#monorepo/*": ["./src/*.js"],
      "#workspace": ["./src/workspace/_.js"],
      "#workspace/*": ["./src/workspace/*.js"],
      "#pnpm": ["./src/pnpm/_.js"],
      "#pnpm/*": ["./src/pnpm/*.js"]
    }
  },
  "include": ["src/**/*.ts"],
  "exclude": ["build", "node_modules", "**/*.bench-d.ts", "**/*.test.ts", "**/*.test-d.ts"]
}
