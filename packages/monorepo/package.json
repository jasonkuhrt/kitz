{
  "name": "@kitz/monorepo",
  "version": "0.0.0-kitz-release",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonkuhrt/kitz.git"
  },
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#monorepo": {
      "types": "./build/_.js",
      "default": "./src/_.ts"
    },
    "#monorepo/*": {
      "types": "./build/*.js",
      "default": "./src/*.ts"
    },
    "#workspace": {
      "types": "./build/workspace/_.js",
      "default": "./src/workspace/_.ts"
    },
    "#workspace/*": {
      "types": "./build/workspace/*.js",
      "default": "./src/workspace/*.ts"
    },
    "#pnpm": {
      "types": "./build/pnpm/_.js",
      "default": "./src/pnpm/_.ts"
    },
    "#pnpm/*": {
      "types": "./build/pnpm/*.js",
      "default": "./src/pnpm/*.ts"
    }
  },
  "types": "./src/_.ts",
  "exports": {
    ".": {
      "types": "./build/_.js",
      "default": "./src/_.ts"
    },
    "./__": {
      "types": "./build/__.js",
      "default": "./src/__.ts"
    },
    "./workspace": {
      "types": "./build/workspace/__.js",
      "default": "./src/workspace/__.ts"
    },
    "./pnpm": {
      "types": "./build/pnpm/__.js",
      "default": "./src/pnpm/__.ts"
    }
  },
  "files": [
    "build",
    "src"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "dev": "tsgo -p tsconfig.build.json --watch",
    "check:types": "tsgo --noEmit",
    "check:lint": "oxlint src/",
    "check:package": "publint && attw --pack --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error"
  },
  "dependencies": {
    "@effect/platform": "^0.94.0",
    "@kitz/core": "workspace:*",
    "@kitz/env": "workspace:*",
    "@kitz/fs": "workspace:*",
    "@kitz/pkg": "workspace:*",
    "@kitz/resource": "workspace:*",
    "effect": "^3.19.5",
    "yaml": "^2.7.1"
  }
}
