{
  "name": "@kitz/pkg",
  "version": "0.0.0-kitz-release",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonkuhrt/kitz.git"
  },
  "description": "Package utilities (manifest schema, manager helpers)",
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#pkg": {
      "types": "./build/_.js",
      "default": "./src/_.ts"
    },
    "#pkg/*": {
      "types": "./build/*.js",
      "default": "./src/*.ts"
    },
    "#moniker": {
      "types": "./build/moniker/_.js",
      "default": "./src/moniker/_.ts"
    },
    "#moniker/*": {
      "types": "./build/moniker/*.js",
      "default": "./src/moniker/*.ts"
    },
    "#manifest": {
      "types": "./build/manifest/_.js",
      "default": "./src/manifest/_.ts"
    },
    "#manifest/*": {
      "types": "./build/manifest/*.js",
      "default": "./src/manifest/*.ts"
    },
    "#manager": {
      "types": "./build/manager/_.js",
      "default": "./src/manager/_.ts"
    },
    "#manager/*": {
      "types": "./build/manager/*.js",
      "default": "./src/manager/*.ts"
    },
    "#pin": {
      "types": "./build/pin/_.js",
      "default": "./src/pin/_.ts"
    },
    "#pin/*": {
      "types": "./build/pin/*.js",
      "default": "./src/pin/*.ts"
    },
    "#range": {
      "types": "./build/range/_.js",
      "default": "./src/range/_.ts"
    },
    "#range/*": {
      "types": "./build/range/*.js",
      "default": "./src/range/*.ts"
    }
  },
  "types": "./src/_.ts",
  "exports": {
    ".": {
      "types": "./build/_.js",
      "default": "./src/_.ts"
    },
    "./__": {
      "types": "./build/__.js",
      "default": "./src/__.ts"
    },
    "./manifest": {
      "types": "./build/manifest/__.js",
      "default": "./src/manifest/__.ts"
    },
    "./manager": {
      "types": "./build/manager/__.js",
      "default": "./src/manager/__.ts"
    },
    "./pin": {
      "types": "./build/pin/_.js",
      "default": "./src/pin/_.ts"
    }
  },
  "files": [
    "build",
    "src"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "dev": "tsgo -p tsconfig.build.json --watch",
    "check:types": "tsgo --noEmit",
    "check:lint": "oxlint src/",
    "check:package": "publint && attw --pack --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error"
  },
  "dependencies": {
    "@effect/platform": "^0.94.0",
    "@kitz/core": "workspace:*",
    "@kitz/env": "workspace:*",
    "@kitz/fs": "workspace:*",
    "@kitz/resource": "workspace:*",
    "@kitz/semver": "workspace:*",
    "@vltpkg/semver": "1.0.0-rc.12",
    "effect": "^3.0.0"
  },
  "devDependencies": {
    "@kitz/assert": "workspace:*",
    "@kitz/test": "workspace:*"
  }
}
