{
  "name": "@kitz/pkg",
  "version": "0.0.0-kitz-release",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonkuhrt/kitz.git"
  },
  "description": "Package utilities (manifest schema, manager helpers)",
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#pkg": {
      "types": "./src/_.ts",
      "default": "./build/_.js"
    },
    "#pkg/*": {
      "types": "./src/*.ts",
      "default": "./build/*.js"
    },
    "#moniker": {
      "types": "./src/moniker/_.ts",
      "default": "./build/moniker/_.js"
    },
    "#moniker/*": {
      "types": "./src/moniker/*.ts",
      "default": "./build/moniker/*.js"
    },
    "#manifest": {
      "types": "./src/manifest/_.ts",
      "default": "./build/manifest/_.js"
    },
    "#manifest/*": {
      "types": "./src/manifest/*.ts",
      "default": "./build/manifest/*.js"
    },
    "#manager": {
      "types": "./src/manager/_.ts",
      "default": "./build/manager/_.js"
    },
    "#manager/*": {
      "types": "./src/manager/*.ts",
      "default": "./build/manager/*.js"
    },
    "#pin": {
      "types": "./src/pin/_.ts",
      "default": "./build/pin/_.js"
    },
    "#pin/*": {
      "types": "./src/pin/*.ts",
      "default": "./build/pin/*.js"
    },
    "#range": {
      "types": "./src/range/_.ts",
      "default": "./build/range/_.js"
    },
    "#range/*": {
      "types": "./src/range/*.ts",
      "default": "./build/range/*.js"
    }
  },
  "types": "./src/_.ts",
  "exports": {
    ".": {
      "types": "./src/_.ts",
      "default": "./build/_.js"
    },
    "./__": {
      "types": "./src/__.ts",
      "default": "./build/__.js"
    },
    "./manifest": {
      "types": "./src/manifest/__.ts",
      "default": "./build/manifest/__.js"
    },
    "./manager": {
      "types": "./src/manager/__.ts",
      "default": "./build/manager/__.js"
    },
    "./pin": {
      "types": "./src/pin/_.ts",
      "default": "./build/pin/_.js"
    }
  },
  "files": [
    "build",
    "src"
  ],
  "scripts": {
    "build": "tsgo -p tsconfig.build.json",
    "dev": "tsgo -p tsconfig.build.json --watch",
    "check:types": "tsgo --noEmit",
    "check:lint": "oxlint src/",
    "check:package": "publint && attw --pack --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error"
  },
  "dependencies": {
    "@effect/platform": "^0.94.0",
    "@kitz/core": "workspace:*",
    "@kitz/env": "workspace:*",
    "@kitz/fs": "workspace:*",
    "@kitz/resource": "workspace:*",
    "@kitz/semver": "workspace:*",
    "@vltpkg/semver": "1.0.0-rc.12",
    "effect": "^3.0.0"
  },
  "devDependencies": {
    "@kitz/assert": "workspace:*",
    "@kitz/test": "workspace:*"
  }
}
