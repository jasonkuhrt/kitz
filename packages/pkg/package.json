{
  "name": "@kitz/pkg",
  "version": "0.0.0-kitz-release",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jasonkuhrt/kitz.git"
  },
  "description": "Package utilities (manifest schema, manager helpers)",
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#pkg": "./src/_.ts",
    "#pkg/*": "./src/*.ts",
    "#moniker": "./src/moniker/_.ts",
    "#moniker/*": "./src/moniker/*.ts",
    "#manifest": "./src/manifest/_.ts",
    "#manifest/*": "./src/manifest/*.ts",
    "#manager": "./src/manager/_.ts",
    "#manager/*": "./src/manager/*.ts",
    "#pin": "./src/pin/_.ts",
    "#pin/*": "./src/pin/*.ts",
    "#range": "./src/range/_.ts",
    "#range/*": "./src/range/*.ts"
  },
  "exports": {
    ".": "./src/_.ts",
    "./__": "./src/__.ts",
    "./manifest": "./src/manifest/__.ts",
    "./manager": "./src/manager/__.ts",
    "./pin": "./src/pin/_.ts"
  },
  "files": [
    "build",
    "src"
  ],
  "scripts": {
    "build": "tsgo -b tsconfig.build.json --clean && tsgo -b tsconfig.build.json",
    "dev": "tsgo -p tsconfig.build.json --watch",
    "check:types": "tsgo --noEmit",
    "check:lint": "oxlint src/",
    "check:package": "publint && attw --pack --ignore-rules no-resolution cjs-resolves-to-esm internal-resolution-error",
    "test": "vitest run --config ../../vitest.config.ts --root .",
    "test:coverage": "vitest run --config ../../vitest.config.ts --root . --coverage",
    "check:cov": "bun run test:coverage"
  },
  "dependencies": {
    "@kitz/core": "workspace:*",
    "@kitz/env": "workspace:*",
    "@kitz/fs": "workspace:*",
    "@kitz/resource": "workspace:*",
    "@kitz/semver": "workspace:*",
    "@vltpkg/semver": "1.0.0-rc.12",
    "effect": "4.0.0-beta.31"
  },
  "devDependencies": {
    "@kitz/assert": "workspace:*",
    "@kitz/test": "workspace:*"
  }
}
