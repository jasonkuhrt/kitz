{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "off",
    "suspicious": "off",
    "pedantic": "off",
    "perf": "off",
    "style": "off",
    "restriction": "off",
    "nursery": "off"
  },
  "jsPlugins": [
    {
      "name": "kitz",
      "specifier": "./tools/oxlint-custom-rules/plugin.mjs"
    }
  ],
  "rules": {
    "kitz/schema-parsing-contract": "error"
  },
  "ignorePatterns": [
    "**/build/**",
    "**/node_modules/**",
    "**/*.d.ts",
    "**/__examples/**",
    "tools/oxlint-custom-rules/tests/fixtures/**"
  ]
}
