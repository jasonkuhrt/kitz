{
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2022",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "rootDir": "src",
    "paths": {
      "#alpha": ["./src/alpha/_.js"],
      "#beta": ["./src/beta/_.js"]
    }
  },
  "include": ["src"]
}
