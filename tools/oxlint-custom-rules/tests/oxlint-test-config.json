{
  "$schema": "../../../node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "off",
    "suspicious": "off",
    "pedantic": "off",
    "perf": "off",
    "style": "off",
    "restriction": "off",
    "nursery": "off"
  },
  "jsPlugins": [
    {
      "name": "kitz",
      "specifier": "../../../packages/oxlint-rules/plugin.mjs"
    }
  ],
  "rules": {
    "kitz/schema/no-json-parse": "warn",
    "kitz/error/no-try-catch": "warn",
    "kitz/effect/no-native-promise-construction": "warn",
    "kitz/ts/no-type-assertion": "warn",
    "kitz/domain/no-native-map-set": "warn",
    "kitz/module/no-nodejs-builtins": "warn",
    "kitz/module/resolver-platform-dispatch": "warn",
    "kitz/schema/schema-parsing-contract": "warn",
    "kitz/error/no-throw": "warn",
    "kitz/effect/no-promise-then-chain": "warn",
    "kitz/effect/no-effect-run-in-library-code": "warn",
    "kitz/error/require-typed-effect-errors": "warn",
    "kitz/schema/require-schema-decode": "warn",
    "kitz/domain/no-process-env": "warn",
    "kitz/domain/no-date-now": "warn",
    "kitz/domain/no-math-random": "warn",
    "kitz/domain/no-console": "warn",
    "kitz/error/require-tagged-error-types": "warn",
    "kitz/module/namespace-file-conventions": "warn",
    "kitz/module/barrel-file-conventions": "warn",
    "kitz/module/module-structure-conventions": "warn",
    "kitz/module/no-deep-imports": "warn",
    "kitz/module/prefer-subpath-imports": "warn",
    "kitz/module/subpath-imports-integrity": [
      "warn",
      {
        "requiredEntryPatterns": [
          "src/*/_.ts",
          "src/*/core/_.ts"
        ]
      }
    ],
    "kitz/module/boundary-contract": [
      "warn",
      {
        "contracts": [
          {
            "files": [
              "packages/release/src/api/executor/workflow.ts"
            ],
            "imports": {
              "ignorePrefixes": [
                "./workflow/"
              ],
              "exactly": [
                "@kitz/flo",
                "../publishing.js",
                "./errors.js"
              ]
            },
            "forbiddenContent": [
              "export const ReleasePayload = Schema.Struct",
              "const releaseWorkflowIdempotencyKey =",
              "ArtifactManifest.make",
              "PublishReceipt.make",
              "RegistryObservation.make",
              "fs.readFile",
              "new Date().toISOString()"
            ],
            "forbiddenContentPatterns": [
              "export\\s*\\{[^}]*tagForRelease[^}]*\\}\\s*from\\s*['\"]\\./workflow/release-info\\.js['\"]"
            ]
          },
          {
            "files": [
              "packages/release/src/api/executor/workflow/activities/verify.ts"
            ],
            "requiredContent": [
              "../../registry-verification.js"
            ],
            "forbiddenContent": [
              "FileSystem",
              "NpmRegistry.NpmCli",
              "ArtifactManifest.make",
              "PublishReceipt.make",
              "RegistryObservation.make",
              "sha256Bytes",
              "new Date"
            ]
          },
          {
            "files": [
              "packages/release/src/api/executor/workflow/activities/prepare.ts"
            ],
            "requiredContent": [
              "Fs.exists(artifact)",
              "Fs.read(artifact)"
            ],
            "forbiddenContent": [
              "FileSystem",
              "fs.exists",
              "fs.readFile"
            ]
          },
          {
            "files": [
              "packages/release/src/api/executor/**"
            ],
            "forbiddenValueImports": [
              "@kitz/cli"
            ],
            "forbiddenValueImportPrefixes": [
              "../renderer",
              "./renderer"
            ]
          },
          {
            "files": [
              "packages/release/src/api/executor/__.ts"
            ],
            "forbiddenContent": [
              "formatExecutionStatus",
              "formatLifecycleEvent",
              "LifecycleEventLine"
            ]
          },
          {
            "files": [
              "packages/release/src/api/publishing/**"
            ],
            "forbiddenContent": [
              "Context.Service"
            ]
          },
          {
            "files": [
              "packages/release/src/api/publishing/__.ts"
            ],
            "forbiddenContentPatterns": [
              "['\"]\\./artifacter\\.js['\"]",
              "['\"]\\./credentials\\.js['\"]",
              "['\"]\\./package-manager\\.js['\"]",
              "['\"]\\./package-registry\\.js['\"]",
              "['\"]\\./release-manager\\.js['\"]",
              "['\"]\\./requests\\.js['\"]",
              "['\"]\\./results\\.js['\"]"
            ],
            "requiredFiles": [
              "conformance.ts"
            ]
          }
        ]
      }
    ],
    "kitz/adt/require-schema-class-statics": "warn",
    "kitz/adt/require-schema-class-ordering": "warn",
    "kitz/adt/require-tagged-union-companion": "warn",
    "kitz/adt/require-tagged-union-namespace": "warn"
  }
}
