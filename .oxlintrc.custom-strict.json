{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "extends": [
    "./.oxlintrc.json"
  ],
  "ignorePatterns": [
    "**/build/**",
    "**/node_modules/**",
    "**/*.d.ts",
    "**/__examples/**",
    "tools/oxlint-custom-rules/tests/fixtures/**"
  ],
  "rules": {
    "kitz/schema/no-json-parse": "error",
    "kitz/error/no-try-catch": "off",
    "kitz/effect/no-native-promise-construction": "error",
    "kitz/ts/no-type-assertion": "off",
    "typescript/no-unsafe-type-assertion": "off",
    "kitz/domain/no-native-map-set": "error",
    "kitz/module/resolver-platform-dispatch": "error",
    "kitz/schema/schema-parsing-contract": "error",
    "kitz/error/no-throw": "off",
    "kitz/effect/no-promise-then-chain": "error",
    "kitz/effect/no-effect-run-in-library-code": "error",
    "kitz/error/require-typed-effect-errors": "error",
    "kitz/schema/require-schema-decode": "error",
    "kitz/domain/no-process-env": "error",
    "kitz/domain/no-date-now": "error",
    "kitz/domain/no-math-random": "error",
    "kitz/domain/no-console": "error",
    "kitz/error/require-tagged-error-types": "error",
    "kitz/module/namespace-file-conventions": "error",
    "kitz/module/barrel-file-conventions": "error",
    "kitz/module/module-structure-conventions": "error",
    "kitz/module/no-deep-imports": "error",
    "kitz/module/prefer-subpath-imports": "error",
    "kitz/module/subpath-imports-integrity": [
      "error",
      {
        "requiredEntryPatterns": [
          "src/*/_.ts",
          "src/*/core/_.ts"
        ]
      }
    ],
    "kitz/module/boundary-contract": [
      "error",
      {
        "contracts": [
          {
            "files": [
              "packages/release/src/api/executor/workflow.ts"
            ],
            "imports": {
              "ignorePrefixes": [
                "./workflow/"
              ],
              "exactly": [
                "@kitz/flo",
                "../publishing.js",
                "./errors.js"
              ]
            },
            "forbiddenContent": [
              "export const ReleasePayload = Schema.Struct",
              "const releaseWorkflowIdempotencyKey =",
              "ArtifactManifest.make",
              "PublishReceipt.make",
              "RegistryObservation.make",
              "fs.readFile",
              "new Date().toISOString()"
            ],
            "forbiddenContentPatterns": [
              "export\\s*\\{[^}]*tagForRelease[^}]*\\}\\s*from\\s*['\"]\\./workflow/release-info\\.js['\"]"
            ]
          },
          {
            "files": [
              "packages/release/src/api/executor/workflow/activities/verify.ts"
            ],
            "requiredContent": [
              "../../registry-verification.js"
            ],
            "forbiddenContent": [
              "FileSystem",
              "NpmRegistry.NpmCli",
              "ArtifactManifest.make",
              "PublishReceipt.make",
              "RegistryObservation.make",
              "sha256Bytes",
              "new Date"
            ]
          },
          {
            "files": [
              "packages/release/src/api/executor/workflow/activities/prepare.ts"
            ],
            "requiredContent": [
              "Fs.exists(artifact)",
              "Fs.read(artifact)"
            ],
            "forbiddenContent": [
              "FileSystem",
              "fs.exists",
              "fs.readFile"
            ]
          },
          {
            "files": [
              "packages/release/src/api/executor/**"
            ],
            "forbiddenValueImports": [
              "@kitz/cli"
            ],
            "forbiddenValueImportPrefixes": [
              "../renderer",
              "./renderer"
            ]
          },
          {
            "files": [
              "packages/release/src/api/executor/__.ts"
            ],
            "forbiddenContent": [
              "formatExecutionStatus",
              "formatLifecycleEvent",
              "LifecycleEventLine"
            ]
          },
          {
            "files": [
              "packages/release/src/api/publishing/**"
            ],
            "forbiddenContent": [
              "Context.Service"
            ]
          },
          {
            "files": [
              "packages/release/src/api/publishing/__.ts"
            ],
            "forbiddenContentPatterns": [
              "['\"]\\./artifacter\\.js['\"]",
              "['\"]\\./credentials\\.js['\"]",
              "['\"]\\./package-manager\\.js['\"]",
              "['\"]\\./package-registry\\.js['\"]",
              "['\"]\\./release-manager\\.js['\"]",
              "['\"]\\./requests\\.js['\"]",
              "['\"]\\./results\\.js['\"]"
            ],
            "requiredFiles": [
              "conformance.ts"
            ]
          }
        ]
      }
    ],
    "kitz/jsdoc/require-on-exports": "off",
    "kitz/jsdoc/min-words": "off",
    "kitz/jsdoc/no-name-restate": "off",
    "kitz/jsdoc/require-example": "off",
    "kitz/jsdoc/usage-tags": "off",
    "kitz/jsdoc/no-weasel-words": "off"
  }
}
